      "source": [
        "fig = plt.figure(figsize=(20, 16), facecolor='#1a1a2e')\n",
        "gs = gridspec.GridSpec(3, 3, figure=fig, hspace=0.5, wspace=0.4)\n",
        "\n",
        "# Colores\n",
        "bg_card   = '#16213e'\n",
        "verde     = '#0f3460'\n",
        "acento1   = '#e94560'\n",
        "acento2   = '#0f9b8e'\n",
        "acento3   = '#f5a623'\n",
        "blanco    = '#ffffff'\n",
        "gris      = '#a0a0b0'\n",
        "\n",
        "# Título\n",
        "fig.text(0.5, 0.97, '🚢 ANÁLISIS DE SUPERVIVENCIA — TITANIC 1912',\n",
        "         ha='center', fontsize=18, fontweight='bold', color=blanco)\n",
        "fig.text(0.5, 0.945, 'Proyecto 1 de Portfolio — Análisis Exploratorio de Datos Reales',\n",
        "         ha='center', fontsize=11, color=gris)\n",
        "\n",
        "# Función KPI\n",
        "def kpi(ax, valor, titulo, color, sub=''):\n",
        "    ax.set_facecolor(bg_card)\n",
        "    ax.axis('off')\n",
        "    ax.text(0.5, 0.60, valor, ha='center', fontsize=24,\n",
        "            fontweight='bold', color=color, transform=ax.transAxes)\n",
        "    ax.text(0.5, 0.30, titulo, ha='center', fontsize=9,\n",
        "            color=blanco, fontweight='bold', transform=ax.transAxes)\n",
        "    if sub:\n",
        "        ax.text(0.5, 0.12, sub, ha='center', fontsize=8,\n",
        "                color=gris, transform=ax.transAxes)\n",
        "\n",
        "# KPIs\n",
        "ax_k1 = fig.add_subplot(gs[0, 0])\n",
        "ax_k2 = fig.add_subplot(gs[0, 1])\n",
        "ax_k3 = fig.add_subplot(gs[0, 2])\n",
        "\n",
        "kpi(ax_k1, '38.2%', '✅ Tasa de Supervivencia', acento2, '340 de 889 pasajeros')\n",
        "kpi(ax_k2, '74.2%', '👩 Supervivencia Femenina', acento3, 'vs 18.9% masculina')\n",
        "kpi(ax_k3, '61.3%', '👶 Supervivencia Niños <10', acento1, '38 de 62 niños')\n",
        "\n",
        "# Gráfica 1 — Supervivencia por clase y género\n",
        "ax1 = fig.add_subplot(gs[1, :2])\n",
        "ax1.set_facecolor(bg_card)\n",
        "pivot = df_limpio.groupby(['Pclass', 'Sex'])['Survived_num'].mean() * 100\n",
        "pivot = pivot.unstack()\n",
        "x = np.arange(len(pivot.index))\n",
        "width = 0.35\n",
        "ax1.bar(x - width/2, pivot['female'], width,\n",
        "        label='Mujer', color=acento3, alpha=0.9)\n",
        "ax1.bar(x + width/2, pivot['male'], width,\n",
        "        label='Hombre', color=acento1, alpha=0.9)\n",
        "ax1.set_title('Supervivencia por Clase y Género (%)',\n",
        "              color=blanco, fontweight='bold')\n",
        "ax1.set_xticks(x)\n",
        "ax1.set_xticklabels(['1ra Clase', '2da Clase', '3ra Clase'], color=gris)\n",
        "ax1.yaxis.set_tick_params(labelcolor=gris)\n",
        "ax1.set_facecolor(bg_card)\n",
        "ax1.spines['bottom'].set_color('#444466')\n",
        "ax1.spines['left'].set_color('#444466')\n",
        "ax1.spines['top'].set_visible(False)\n",
        "ax1.spines['right'].set_visible(False)\n",
        "ax1.legend(facecolor=bg_card, labelcolor=gris)\n",
        "ax1.set_ylabel('% Supervivencia', color=gris)\n",
        "for i, (f, m) in enumerate(zip(pivot['female'], pivot['male'])):\n",
        "    ax1.text(i - width/2, f + 1, f'{f:.0f}%',\n",
        "             ha='center', color=gris, fontsize=8)\n",
        "    ax1.text(i + width/2, m + 1, f'{m:.0f}%',\n",
        "             ha='center', color=gris, fontsize=8)\n",
        "\n",
        "# Gráfica 2 — Niños por clase\n",
        "ax2 = fig.add_subplot(gs[1, 2])\n",
        "ax2.set_facecolor(bg_card)\n",
        "ninos_clase = df_limpio[df_limpio['Age'] < 10].groupby('Pclass')['Survived_num'].agg(\n",
        "    Total='count', Sobrevivieron='sum'\n",
        ")\n",
        "ninos_clase['Fallecieron'] = ninos_clase['Total'] - ninos_clase['Sobrevivieron']\n",
        "ax2.bar(ninos_clase.index, ninos_clase['Sobrevivieron'],\n",
        "        label='Sobrevivieron', color=acento2)\n",
        "ax2.bar(ninos_clase.index, ninos_clase['Fallecieron'],\n",
        "        bottom=ninos_clase['Sobrevivieron'],\n",
        "        label='Fallecieron', color=acento1)\n",
        "ax2.set_title('Niños <10 años por Clase', color=blanco, fontweight='bold')\n",
        "ax2.set_xlabel('Clase', color=gris)\n",
        "ax2.set_ylabel('Cantidad', color=gris)\n",
        "ax2.tick_params(colors=gris)\n",
        "ax2.spines['bottom'].set_color('#444466')\n",
        "ax2.spines['left'].set_color('#444466')\n",
        "ax2.spines['top'].set_visible(False)\n",
        "ax2.spines['right'].set_visible(False)\n",
        "ax2.legend(facecolor=bg_card, labelcolor=gris, fontsize=8)\n",
        "\n",
        "# Gráfica 3 — Distribución de tarifas por clase\n",
        "ax3 = fig.add_subplot(gs[2, :])\n",
        "ax3.set_facecolor(bg_card)\n",
        "colores_clases = {'1': acento3, '2': acento2, '3': acento1}\n",
        "for clase, color in colores_clases.items():\n",
        "    datos = df_limpio[df_limpio['Pclass'] == clase]['Fare']\n",
        "    ax3.hist(datos, bins=30, alpha=0.6,\n",
        "             color=color, label=f'Clase {clase}')\n",
        "ax3.set_title('Distribución de Tarifas por Clase',\n",
        "              color=blanco, fontweight='bold')\n",
        "ax3.set_xlabel('Tarifa ($)', color=gris)\n",
        "ax3.set_ylabel('Cantidad de pasajeros', color=gris)\n",
        "ax3.tick_params(colors=gris)\n",
        "ax3.spines['bottom'].set_color('#444466')\n",
        "ax3.spines['left'].set_color('#444466')\n",
        "ax3.spines['top'].set_visible(False)\n",
        "ax3.spines['right'].set_visible(False)\n",
        "ax3.legend(facecolor=bg_card, labelcolor=gris)\n",
        "ax3.set_xlim(0, 300)\n",
        "\n",
        "plt.savefig('proyecto1_titanic.png', dpi=150,\n",
        "            bbox_inches='tight', facecolor='#1a1a2e')\n",
        "plt.show()\n",
        "print(\"✅ Proyecto 1 guardado como proyecto1_titanic.png\")"
